{% extends 'base.html.twig' %}

{% block title %}Contact
{% endblock %}

{% block body %}
	<main
		class="main">
		{# Page Hero #}
		<section class="page-hero">
			<div class="container">
				<h1 class="page-title fade-up">Restons en contact</h1>
				<p class="page-subtitle fade-up delay-200">N'hésitez pas à me contacter pour discuter de vos projets ou simplement échanger.</p>
			</div>
		</section>

		{# Contact Section #}
		<section class="contact-page-section">
			<div class="container">
				<div
					class="contact-content-grid">
					{# Contact Information #}
					<div class="contact-info fade-up delay-300">
						<div class="contact-info-card">
							<h2 class="contact-info-title">Mes coordonnées</h2>
							<p class="contact-info-text">Vous pouvez me joindre par différents moyens. Je suis disponible pour discuter de vos projets et répondre à vos questions.</p>

							<div
								class="contact-methods">
								{# Email principal #}
								<div class="contact-method">
									<div class="contact-method-icon">
										<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
											<polyline points="22,6 12,13 2,6"></polyline>
										</svg>
									</div>
									<div class="contact-method-content">
										<h3 class="contact-method-title">Email principal</h3>
										<a href="mailto:contact@kaelian.dev" class="contact-method-link">contact@kaelian.dev</a>
									</div>
								</div>

								{# Email EPSI #}
								<div class="contact-method">
									<div class="contact-method-icon">
										<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
											<polyline points="22,6 12,13 2,6"></polyline>
										</svg>
									</div>
									<div class="contact-method-content">
										<h3 class="contact-method-title">Email EPSI</h3>
										<a href="mailto:kaelian.baudelet@ecoles-epsi.net" class="contact-method-link">kaelian.baudelet@ecoles-epsi.net</a>
									</div>
								</div>
								<div class="contact-method">
									<div class="contact-method-icon">
										<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
										</svg>
									</div>
									<div class="contact-method-content">
										<h3 class="contact-method-title">Téléphone</h3>
										<a href="tel:+3361796652" class="contact-method-link">+33 06 17 96 65 2</a>
									</div>
								</div>
							</div>

							{# Téléphone #}


							{# Localisation #}
							<div class="contact-location">
								<h3 class="contact-location-title">Ma localisation</h3>
								<div class="location-address">
									<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
										<circle cx="12" cy="10" r="3"></circle>
									</svg>
									<span>62300 Lens, France</span>
								</div>
								<div class="map-container">
									<link rel="preload" as="image" href="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d10192.342156849783!2d2.807449!3d50.430000!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47dd3e32b6e0b3a9%3A0x40a5fb99a3f2f70!2s62300%20Lens!5e0!3m2!1sfr!2sfr!4v1730910000000">
									<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d10192.342156849783!2d2.807449!3d50.430000!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47dd3e32b6e0b3a9%3A0x40a5fb99a3f2f70!2s62300%20Lens!5e0!3m2!1sfr!2sfr!4v1730910000000" width="100%" height="250" style="border:0; border-radius: 0.75rem;" allowfullscreen="" loading="eager" referrerpolicy="no-referrer-when-downgrade"></iframe>
								</div>
							</div>

							{# Social Links #}
							<div class="contact-socials">
								<h3 class="contact-socials-title">Retrouvez-moi également sur</h3>
								<div class="social-links">
									<a href="https://x.com/kaelianbaudelet" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="X (Twitter)">
										<svg width="20" height="20" viewbox="0 0 24 24" fill="currentColor">
											<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
										</svg>
									</a>
									<a href="https://linkedin.com/in/kaelianbaudelet" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
										<svg width="20" height="20" viewbox="0 0 24 24" fill="currentColor">
											<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
										</svg>
									</a>
									<a href="https://github.com/kaelianbaudelet" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
										<svg width="20" height="20" viewbox="0 0 24 24" fill="currentColor">
											<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
										</svg>
									</a>

								</div>
							</div>
						</div>
					</div>

					{# Contact Form #}
					<div class="contact-form-wrapper fade-up delay-400">
						<div class="contact-form-card">
							<h2 class="contact-form-title">Envoyez-moi un message</h2>
							<p class="contact-form-text">Remplissez le formulaire ci-dessous et je vous répondrai dans les plus brefs délais.</p>

							{% if success %}
								<div class="contact-success-message">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
										<polyline points="22 4 12 14.01 9 11.01"></polyline>
									</svg>
									<p>Votre message a été envoyé avec succès ! Je vous répondrai dans les plus brefs délais.</p>
								</div>
							{% endif %}

							{% if error %}
								<div class="contact-error-message">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="12" r="10"></circle>
										<line x1="15" y1="9" x2="9" y2="15"></line>
										<line x1="9" y1="9" x2="15" y2="15"></line>
									</svg>
									<p>{{ error }}</p>
								</div>
							{% endif %}

							<form method="POST" action="{{ path('app_contact') }}" class="contact-form">
								<div class="form-group">
									<label for="name" class="form-label">Nom complet</label>
									<input type="text" id="name" name="name" class="form-input" placeholder="Votre nom" required value="{{ name ?? '' }}">
								</div>

								<div class="form-group">
									<label for="email" class="form-label">Adresse email</label>
									<input type="email" id="email" name="email" class="form-input" placeholder="votre@email.com" required value="{{ email ?? '' }}">
								</div>

								<div class="form-group">
									<label for="subject" class="form-label">Sujet</label>
									<input type="text" id="subject" name="subject" class="form-input" placeholder="Sujet de votre message" required value="{{ subject ?? '' }}">
								</div>

								<div class="form-group">
									<label for="message" class="form-label">Message</label>
									<textarea id="message" name="message" class="form-textarea" rows="6" placeholder="Votre message..." required>{{ message ?? '' }}</textarea>
								</div>

								<button type="submit" class="btn btn-primary btn-large btn-block">
									<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="22" y1="2" x2="11" y2="13"></line>
										<polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
									</svg>
									Envoyer le message
								</button>
							</form>
						</div>
					</div>
				</div>
			</div>
		</section>


	</main>
{% endblock %}
