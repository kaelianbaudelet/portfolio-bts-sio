					</a>
					<a href="{{ path('app_tech_watch') }}" class="cta-card">
						<h3 class="cta-title">
							<svg width="22" height="22" viewbox="0 0 24 24" fill="none" style="vertical-align:middle; margin-right:0.45em;">
