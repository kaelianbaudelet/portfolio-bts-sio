{% extends 'admin/base.html.twig' %}

{% block title %}Articles de Veille Technologique{% endblock %}

{% block body %}
	<div class="admin-header">
		<div>
			<h1 class="admin-page-title">Articles de Veille Technologique</h1>
			<p class="admin-page-subtitle">Gérez les articles de votre veille technologique</p>
		</div>
		<a href="{{ path('admin_tech_watch_article_new') }}" class="btn btn-primary">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<line x1="12" y1="5" x2="12" y2="19"></line>
				<line x1="5" y1="12" x2="19" y2="12"></line>
			</svg>
			Nouvel article
		</a>
	</div>

	<div class="admin-section">
		{% if articles|length == 0 %}
			<div class="admin-empty-state">
				<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
					<polyline points="14 2 14 8 20 8"></polyline>
					<line x1="16" y1="13" x2="8" y2="13"></line>
					<line x1="16" y1="17" x2="8" y2="17"></line>
					<polyline points="10 9 9 9 8 9"></polyline>
				</svg>
				<h3>Aucun article</h3>
				<p>Commencez par ajouter votre premier article de veille</p>
				<a href="{{ path('admin_tech_watch_article_new') }}" class="btn btn-primary">Ajouter un article</a>
			</div>
		{% else %}
			<div class="admin-grid">
				{% for article in articles %}
					<div class="admin-project-card" id="article-{{ article.id }}">
						<div class="admin-project-card-header">
							{% if article.image %}
								<img src="{{ asset('uploads/' ~ article.image) }}" alt="{{ article.title }}" class="admin-project-image">
							{% else %}
								<div class="admin-project-placeholder">
									<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
										<circle cx="8.5" cy="8.5" r="1.5"></circle>
										<polyline points="21 15 16 10 5 21"></polyline>
									</svg>
								</div>
							{% endif %}
						</div>
						<div class="admin-project-card-body">
							<div class="admin-project-card-title">
								<h3>{{ article.title }}</h3>
								{% if not article.isVisible %}
									<span class="admin-badge admin-badge-gray">Masqué</span>
								{% endif %}
							</div>
							<p class="admin-project-card-description">
								{{ article.description|length > 120 ? article.description|slice(0, 120) ~ '...' : article.description }}
							</p>
							<div class="admin-article-meta">
								<span class="admin-meta-item">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
									</svg>
									{{ article.author }}
								</span>
								<span class="admin-meta-item">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
										<line x1="16" y1="2" x2="16" y2="6"></line>
										<line x1="8" y1="2" x2="8" y2="6"></line>
										<line x1="3" y1="10" x2="21" y2="10"></line>
									</svg>
									{{ article.publishedAt|date('d/m/Y') }}
								</span>
							</div>
						</div>
						<div class="admin-project-card-footer">
							<a href="{{ path('admin_tech_watch_article_edit', {id: article.id}) }}" class="admin-icon-btn" title="Modifier">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
									<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
								</svg>
							</a>
							<button class="admin-icon-btn admin-icon-btn-danger delete-article-btn" data-article-id="{{ article.id }}" title="Supprimer">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="3 6 5 6 21 6"></polyline>
									<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
								</svg>
							</button>
						</div>
					</div>
				{% endfor %}
			</div>
		{% endif %}
	</div>

{% endblock %}

{% block javascripts %}
	<script nonce="{{ csp_nonce() }}">
		document.addEventListener('DOMContentLoaded', function() {
			const deleteButtons = document.querySelectorAll('.delete-article-btn');

			deleteButtons.forEach(button => {
				button.addEventListener('click', async function() {
					const id = this.dataset.articleId;

					if (!confirm('Êtes-vous sûr de vouloir supprimer cet article ?')) {
						return;
					}

					try {
						const response = await fetch(`/admin/tech-watch-articles/${id}/delete`, {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json'
							}
						});

						if (response.ok) {
							const card = document.getElementById(`article-${id}`);
							if (card) {
								card.style.opacity = '0';
								card.style.transform = 'scale(0.9)';
								setTimeout(() => card.remove(), 300);
							}
						} else {
							alert('Une erreur est survenue lors de la suppression de l\'article.');
						}
					} catch (error) {
						console.error('Error deleting article:', error);
						alert('Une erreur est survenue lors de la suppression de l\'article.');
					}
				});
			});
		});
	</script>
{% endblock %}
