{% extends 'admin/base.html.twig' %}
{% block title %}Formations{% endblock %}
{% block body %}
<div class="admin-header">
    <div>
        <h1 class="admin-page-title">Formations</h1>
        <p class="admin-page-subtitle">Gérez vos formations académiques</p>
    </div>
    <a href="{{ path('admin_education_new') }}" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nouvelle formation
    </a>
</div>
<div class="admin-section">
    {% if educations|length == 0 %}
        <div class="admin-empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            <h3>Aucune formation</h3>
            <p>Commencez par ajouter votre première formation académique</p>
            <a href="{{ path('admin_education_new') }}" class="btn btn-primary">Ajouter une formation</a>
        </div>
    {% else %}
    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Diplôme</th>
                    <th>Institution</th>
                    <th>Période</th>
                    <th>Ordre</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for education in educations %}
                <tr id="education-{{ education.id }}">
                    <td><strong>{{ education.degree }}</strong></td>
                    <td>{{ education.institution }}</td>
                    <td>{{ education.startDate }} - {{ education.endDate }}</td>
                    <td>{{ education.displayOrder }}</td>
                    <td>
                        <div class="admin-table-actions">
                            <a href="{{ path('admin_education_edit', {id: education.id}) }}" class="admin-table-action" title="Modifier">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </a>
                            <button onclick="deleteEducation({{ education.id }})" class="admin-table-action admin-table-action-danger" title="Supprimer">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
{% block javascripts %}
<script nonce="{{ csp_nonce() }}">
async function deleteEducation(id) {
    if (!confirm('Voulez-vous vraiment supprimer cette formation ?')) return;
    try {
        const response = await fetch(`/admin/education/${id}/delete`, {method: 'POST'});
        if (response.ok) document.getElementById(`education-${id}`).remove();
    } catch (error) {
        alert('Erreur lors de la suppression.');
    }
}
</script>
{% endblock %}
