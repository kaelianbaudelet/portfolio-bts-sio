{% if recentMessages|length > 0 %}
<div class="admin-section">
    <div class="admin-section-header">
        <h2 class="admin-section-title">Messages récents</h2>
        <a href="{{ path('admin_messages') }}" class="admin-link-btn">Voir tout</a>
    </div>

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Statut</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Sujet</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for message in recentMessages %}
                <tr id="message-{{ message.id }}" class="{% if not message.isRead %}admin-table-row-unread{% endif %}">
                    <td>
                        {% if message.isRead %}
                            <span class="admin-badge admin-badge-gray">Lu</span>
                        {% else %}
                            <span class="admin-badge admin-badge-success">Nouveau</span>
                        {% endif %}
                    </td>
                    <td><strong>{{ message.name }}</strong></td>
                    <td>{{ message.email }}</td>
                    <td>{{ message.subject|length > 40 ? message.subject|slice(0, 40) ~ '...' : message.subject }}</td>
                    <td>{{ message.createdAt|date('d/m/Y H:i') }}</td>
                    <td>
                        <button onclick="viewMessage({{ message.id }}, '{{ message.name|e('js') }}', '{{ message.email|e('js') }}', '{{ message.subject|e('js') }}', {{ message.message|json_encode|e('js') }}, '{{ message.createdAt|date('d/m/Y H:i') }}', {{ message.isRead ? 'true' : 'false' }})" class="admin-table-action" title="Voir">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

<!-- Message Modal -->
<div id="messageModal" class="admin-modal">
    <div class="admin-modal-overlay" onclick="closeMessageModal()"></div>
    <div class="admin-modal-content">
        <div class="admin-modal-header">
            <h3 class="admin-modal-title">Détails du message</h3>
            <button onclick="closeMessageModal()" class="admin-modal-close">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="admin-modal-body">
            <div class="admin-message-detail">
                <div class="admin-message-detail-row">
                    <strong>De :</strong>
                    <span id="modalName"></span>
                </div>
                <div class="admin-message-detail-row">
                    <strong>Email :</strong>
                    <a id="modalEmail" href="" class="admin-link"></a>
                </div>
                <div class="admin-message-detail-row">
                    <strong>Sujet :</strong>
                    <span id="modalSubject"></span>
                </div>
                <div class="admin-message-detail-row">
                    <strong>Date :</strong>
                    <span id="modalDate"></span>
                </div>
                <div class="admin-message-detail-message">
                    <strong>Message :</strong>
                    <div id="modalMessage"></div>
                </div>
            </div>
        </div>
        <div class="admin-modal-footer">
            <button id="modalReplyBtn" class="btn btn-primary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 17 4 12 9 7"></polyline>
                    <path d="M20 18v-2a4 4 0 0 0-4-4H4"></path>
                </svg>
                Répondre
            </button>
            <button onclick="closeMessageModal()" class="btn btn-secondary">Fermer</button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script nonce="{{ csp_nonce() }}">
let currentMessageId = null;

function viewMessage(id, name, email, subject, message, date, isRead) {
    currentMessageId = id;
    document.getElementById('modalName').textContent = name;
    document.getElementById('modalEmail').textContent = email;
    document.getElementById('modalEmail').href = 'mailto:' + email;
    document.getElementById('modalSubject').textContent = subject;
    document.getElementById('modalMessage').textContent = message;
    document.getElementById('modalDate').textContent = date;
    document.getElementById('modalReplyBtn').onclick = () => window.location.href = 'mailto:' + email + '?subject=Re: ' + encodeURIComponent(subject);

    document.getElementById('messageModal').classList.add('active');

    if (!isRead) {
        markAsRead(id);
    }
}

function closeMessageModal() {
    document.getElementById('messageModal').classList.remove('active');
}

async function markAsRead(id) {
    try {
        const response = await fetch(`/admin/messages/${id}/read`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        });

        if (response.ok) {
            const row = document.getElementById(`message-${id}`);
            if (row) {
                row.classList.remove('admin-table-row-unread');
                const badge = row.querySelector('.admin-badge');
                if (badge) {
                    badge.classList.remove('admin-badge-success');
                    badge.classList.add('admin-badge-gray');
                    badge.textContent = 'Lu';
                }
            }
            // Update unread messages count
            location.reload();
        }
    } catch (error) {
        console.error('Error marking message as read:', error);
    }
}
</script>
{% endblock %}
