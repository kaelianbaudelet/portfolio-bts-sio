{% extends 'admin/base.html.twig' %}
{% block title %}
	{{ internship ? 'Modifier' : 'Nouveau' }}
	stage
{% endblock %}
{% block body %}
	<div class="admin-header">
		<div>
			<h1 class="admin-page-title">{{ internship ? 'Modifier le stage' : 'Nouveau stage' }}</h1>
			<p class="admin-page-subtitle">{{ internship ? 'Modifiez les informations du stage' : 'Ajoutez un nouveau stage' }}</p>
		</div>
	</div>
	<div class="admin-form-container">
		<form method="post" class="admin-form">
			<div class="form-section">
				<h3 class="form-section-title">Informations générales</h3>

				<div class="admin-form-grid">
					<div class="form-group">
						<label for="title" class="form-label">Titre du stage *</label>
						<input type="text" id="title" name="title" class="form-input" required value="{{ internship ? internship.title : '' }}" placeholder="Ex: Stage Développeur Full Stack">
					</div>
					<div class="form-group">
						<label for="company" class="form-label">Entreprise *</label>
						<input type="text" id="company" name="company" class="form-input" required value="{{ internship ? internship.company : '' }}" placeholder="Ex: Tech Company">
					</div>
				</div>

				<div class="form-group">
					<label class="form-label">Logo de l'entreprise</label>
					<input type="hidden" id="companyLogo" name="companyLogo" value="{{ internship ? internship.companyLogo : '' }}">

					<div class="image-selector-container">
						<div class="image-preview" id="logoPreview">
							{% if internship and internship.companyLogo %}
								<img src="{{ asset('uploads/' ~ internship.companyLogo) }}" alt="Aperçu">
								<button type="button" class="image-remove-btn" id="removeLogoBtn">
									<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<line x1="18" y1="6" x2="6" y2="18"></line>
										<line x1="6" y1="6" x2="18" y2="18"></line>
									</svg>
								</button>
							{% else %}
								<div class="image-placeholder">
									<svg width="48" height="48" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
										<circle cx="8.5" cy="8.5" r="1.5"></circle>
										<polyline points="21 15 16 10 5 21"></polyline>
									</svg>
									<p>Aucune image sélectionnée</p>
								</div>
							{% endif %}
						</div>
						<button type="button" class="btn btn-secondary" id="selectLogoBtn">
							<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
								<circle cx="8.5" cy="8.5" r="1.5"></circle>
								<polyline points="21 15 16 10 5 21"></polyline>
							</svg>
							Choisir un logo
						</button>
					</div>
					<small class="form-help">Formats acceptés: JPG, PNG, SVG</small>
				</div>
			</div>

			<div class="form-section">
				<h3 class="form-section-title">Période et année</h3>

				<div class="admin-form-grid admin-form-grid-3">
					<div class="form-group">
						<label for="startDate" class="form-label">Date de début *</label>
						<input type="date" id="startDate" name="startDate" class="form-input" required value="{{ internship and internship.startDate ? internship.startDate.format('Y-m-d') : '' }}">
						<small class="form-help">Sera affiché:
							{{ internship and internship.startDate }}</small>
					</div>
					<div class="form-group">
						<label for="endDate" class="form-label">Date de fin</label>
						<input type="date" id="endDate" name="endDate" class="form-input" value="{{ internship and internship.endDate ? internship.endDate.format('Y-m-d') : '' }}">
						<small class="form-help">Laissez vide pour "En cours"</small>
					</div>
					<div class="form-group">
						<label for="year" class="form-label">Année *</label>
						<input type="number" id="year" name="year" class="form-input" required value="{{ internship ? internship.year : 'now'|date('Y') }}" min="2000" max="2100">
						<small class="form-help">Année de réalisation du stage</small>
					</div>
				</div>
			</div>

			<div class="form-section">
				<h3 class="form-section-title">Description</h3>

				<div class="form-group">
					<label for="shortDescription" class="form-label">Description courte</label>
					<textarea id="shortDescription" name="shortDescription" class="form-textarea" rows="3">{{ internship ? internship.shortDescription : '' }}</textarea>
					<small class="form-help">Affichée sur la carte du stage (150 caractères recommandés)</small>
				</div>

				<div class="form-group">
					<label for="fullDescription" class="form-label">Description complète</label>
					<textarea id="fullDescription" name="fullDescription" class="form-textarea" rows="6">{{ internship ? internship.fullDescription : '' }}</textarea>
					<small class="form-help">Affichée dans la modal de détails</small>
				</div>

				<div class="form-group">
					<label for="tasks" class="form-label">Missions réalisées</label>
					<textarea id="tasks" name="tasks" class="form-textarea" rows="6">{{ internship ? internship.tasks|join('\n') : '' }}</textarea>
					<small class="form-help">Une mission par ligne (sera affichée avec des puces)</small>
				</div>
			</div>

			<div class="form-section">
				<h3 class="form-section-title">Projets associés</h3>

				<div class="form-group">
					<label class="form-label">Sélectionnez les projets réalisés durant ce stage</label>
					<div class="projects-selection">
						{% if projects|length > 0 %}
							<div class="projects-grid">
								{% for project in projects %}
									<label class="project-checkbox-card">
										<input type="checkbox" name="projects[]" value="{{ project.id }}" {{ internship and project in internship.projects ? 'checked' : '' }}>
										<div class="project-checkbox-content">
											{% if project.image %}
												<img src="/uploads/{{ project.image }}" alt="{{ project.title }}" class="project-thumbnail">
											{% else %}
												<div class="project-thumbnail-placeholder">
													<i class="fas fa-project-diagram"></i>
												</div>
											{% endif %}
											<div class="project-info">
												<strong>{{ project.title }}</strong>
												<p>{{ project.shortDescription|slice(0, 60) }}...</p>
											</div>
										</div>
									</label>
								{% endfor %}
							</div>
						{% else %}
							<p style="color: var(--text-secondary);">Aucun projet disponible.
								<a href="{{ path('admin_project_new') }}">Créer un projet</a>
							</p>
						{% endif %}
					</div>
				</div>
			</div>

			<div class="form-section">
				<h3 class="form-section-title">Options d'affichage</h3>

				<div class="admin-form-grid">
					<div class="form-group">
						<label for="displayOrder" class="form-label">Ordre d'affichage</label>
						<input type="number" id="displayOrder" name="displayOrder" class="form-input" value="{{ internship ? internship.displayOrder : 0 }}">
						<small class="form-help">Les stages avec un ordre plus petit apparaissent en premier</small>
					</div>
					<div class="form-group">
						<label class="admin-checkbox">
							<input type="checkbox" name="isVisible" value="1" {{ internship and internship.isVisible ? 'checked' : (not internship ? 'checked' : '') }}>
							<span>Visible sur le site public</span>
						</label>
					</div>
				</div>
			</div>

			<div class="admin-form-actions">
				<button type="submit" class="btn btn-primary btn-large">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
						<polyline points="17 21 17 13 7 13 7 21"></polyline>
						<polyline points="7 3 7 8 15 8"></polyline>
					</svg>
					{{ internship ? 'Mettre à jour' : 'Créer le stage' }}
				</button>
				<a href="{{ path('admin_internships') }}" class="btn btn-secondary btn-large">Annuler</a>
			</div>
		</form>
	</div>

	<!-- Modal réutilisable pour sélection de fichiers/images -->
	<div class="media-selector-modal" id="mediaSelectorModal">
		<div class="modal-dialog">
			<div class="modal-header">
				<h3 class="modal-title" id="modalTitle">Sélectionner une image</h3>
				<button type="button" class="modal-close" id="closeModalBtn">
					<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>

			<div class="modal-tabs">
				<button class="modal-tab active" data-tab="gallery">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<circle cx="8.5" cy="8.5" r="1.5"></circle>
						<polyline points="21 15 16 10 5 21"></polyline>
					</svg>
					Galerie
				</button>
				<button class="modal-tab" data-tab="upload">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
						<polyline points="17 8 12 3 7 8"></polyline>
						<line x1="12" y1="3" x2="12" y2="15"></line>
					</svg>
					Upload
				</button>
			</div>

			<div
				class="modal-body">
				<!-- Gallery Tab -->
				<div class="modal-tab-content active" id="galleryTab">
					<div class="modal-gallery-grid" id="modalGalleryGrid">
						<div class="loading-spinner">Chargement...</div>
					</div>
				</div>

				<!-- Upload Tab -->
				<div class="modal-tab-content" id="uploadTab">
					<div class="modal-upload-area">
						<div class="upload-drop-zone" id="modalDropZone">
							<svg width="64" height="64" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
								<polyline points="17 8 12 3 7 8"></polyline>
								<line x1="12" y1="3" x2="12" y2="15"></line>
							</svg>
							<p class="upload-text">Glissez-déposez vos fichiers ici</p>
							<p class="upload-subtext">ou</p>
							<button type="button" class="btn btn-primary" id="modalSelectFileBtn">
								Sélectionner des fichiers
							</button>
							<input type="file" id="modalFileInput" multiple style="display: none;" accept="image/*">
							<p class="upload-hint" id="modalUploadHint">JPG, PNG, GIF, WebP ou SVG (Max 5MB)</p>
						</div>

						<div class="upload-progress" id="modalUploadProgress" style="display: none;">
							<div class="upload-progress-bar">
								<div class="upload-progress-fill" id="modalProgressFill"></div>
							</div>
							<p id="modalUploadStatus">Upload en cours...</p>
						</div>
					</div>
				</div>
			</div>

			<div class="modal-footer" id="modalFooter" style="display: none;">
				<button type="button" class="btn btn-secondary" id="modalCancelBtn">Annuler</button>
				<button type="button" class="btn btn-primary" id="modalValidateBtn">
					Sélectionner
					<span id="selectedCount"></span>
				</button>
			</div>
		</div>
	</div>

	<style>
		.form-section {
			background: var(--card-bg);
			padding: 2rem;
			border-radius: 8px;
			margin-bottom: 2rem;
		}

		.form-section-title {
			font-size: 1.25rem;
			font-weight: 700;
			color: var(--text-primary);
			margin: 0 0 1.5rem;
			padding-bottom: 0.75rem;
			border-bottom: 2px solid var(--accent-color);
		}

		.admin-form-grid-3 {
			grid-template-columns: repeat(3, 1fr);
		}

		.projects-selection {
			margin-top: 1rem;
		}

		.projects-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			gap: 1rem;
			margin-top: 1rem;
		}

		.project-checkbox-card {
			position: relative;
			cursor: pointer;
			display: block;
		}

		.project-checkbox-card input[type="checkbox"] {
			position: absolute;
			opacity: 0;
			cursor: pointer;
		}

		.project-checkbox-content {
			display: flex;
			gap: 1rem;
			padding: 1rem;
			background: var(--bg-primary);
			border: 2px solid #ddd;
			border-radius: 8px;
			transition: all 0.3s ease;
		}

		.project-checkbox-card:hover .project-checkbox-content {
			border-color: var(--accent-color);
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		}

		.project-checkbox-card input[type="checkbox"]:checked ~ .project-checkbox-content {
			background: rgba(102, 126, 234, 0.1);
			border-color: var(--accent-color);
			box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
		}

		.project-thumbnail {
			width: 80px;
			height: 80px;
			object-fit: cover;
			border-radius: 6px;
			flex-shrink: 0;
		}

		.project-thumbnail-placeholder {
			width: 80px;
			height: 80px;
			background: var(--accent-color);
			border-radius: 6px;
			display: flex;
			align-items: center;
			justify-content: center;
			color: white;
			font-size: 1.5rem;
			flex-shrink: 0;
		}
	</style>

	<script src="{{ asset('assets/scripts/internship-form.js') }}"></script>
{% endblock %}
