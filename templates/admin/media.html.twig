{% extends 'admin/base.html.twig' %}

{% block title %}Médias
{% endblock %}

{% block body %}
	<div class="admin-header">
		<h1 class="admin-page-title">Gestion des Médias</h1>
		<p class="admin-page-subtitle">Gérez vos images et fichiers pour les projets</p>
	</div>

	<div class="admin-section">
		<div class="admin-section-header">
			<h2 class="admin-section-title">Uploader un fichier</h2>
		</div>

		<div class="media-upload-area">
			<div class="upload-type-selector">
				<button class="upload-type-btn active" data-type="image">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<circle cx="8.5" cy="8.5" r="1.5"></circle>
						<polyline points="21 15 16 10 5 21"></polyline>
					</svg>
					Images
				</button>
				<button class="upload-type-btn" data-type="file">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
						<polyline points="13 2 13 9 20 9"></polyline>
					</svg>
					Fichiers
				</button>
			</div>

			<div class="upload-drop-zone" id="dropZone">
				<svg width="64" height="64" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
					<polyline points="17 8 12 3 7 8"></polyline>
					<line x1="12" y1="3" x2="12" y2="15"></line>
				</svg>
				<p class="upload-text">Glissez-déposez vos fichiers ici</p>
				<p class="upload-subtext">ou</p>
				<button class="btn btn-primary" id="selectFileBtn">
					Sélectionner un fichier
				</button>
				<input type="file" id="fileInput" accept="image/jpeg,image/png,image/gif,image/webp,image/svg+xml" style="display: none;">
				<p class="upload-hint" id="uploadHint">JPG, PNG, GIF, WebP ou SVG (Max 5MB)</p>
			</div>

			<div class="upload-progress" id="uploadProgress" style="display: none;">
				<div class="upload-progress-bar">
					<div class="upload-progress-fill" id="progressFill"></div>
				</div>
				<p id="uploadStatus">Upload en cours...</p>
			</div>
		</div>
	</div>

	<div class="admin-section">
		<div class="admin-section-header">
			<h2 class="admin-section-title">Bibliothèque de médias ({{ files|length }})</h2>
		</div>

		{% if files|length > 0 %}
			<div class="media-grid" id="mediaGrid">
				{% for file in files %}
					<div class="media-item" data-filename="{{ file.name }}" data-type="{{ file.type }}">
						<div class="media-preview">
							{% if file.type == 'image' %}
								<img src="{{ file.url }}" alt="{{ file.name }}" loading="lazy">
							{% else %}
								<div class="file-icon">
									{% if file.type == 'document' %}
										<svg width="64" height="64" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
											<polyline points="14 2 14 8 20 8"></polyline>
											<line x1="16" y1="13" x2="8" y2="13"></line>
											<line x1="16" y1="17" x2="8" y2="17"></line>
											<polyline points="10 9 9 9 8 9"></polyline>
										</svg>
									{% elseif file.type == 'archive' %}
										<svg width="64" height="64" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<polyline points="21 8 21 21 3 21 3 8"></polyline>
											<rect x="1" y="3" width="22" height="5"></rect>
											<line x1="10" y1="12" x2="14" y2="12"></line>
										</svg>
									{% else %}
										<svg width="64" height="64" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
											<polyline points="13 2 13 9 20 9"></polyline>
										</svg>
									{% endif %}
								</div>
							{% endif %}
						</div>
						<div class="media-info">
							<p class="media-name" title="{{ file.name }}">{{ file.name }}</p>
							<p class="media-size">{{ (file.size / 1024)|round(2) }}
								KB</p>
						</div>
						<div class="media-actions">

							<button class="btn btn-sm btn-danger delete-media-btn" data-filename="{{ file.name }}" title="Supprimer">
								<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="3 6 5 6 21 6"></polyline>
									<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
								</svg>
							</button>
						</div>
					</div>
				{% endfor %}
			</div>
		{% else %}
			<div class="admin-empty-state">
				<svg width="64" height="64" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
					<circle cx="8.5" cy="8.5" r="1.5"></circle>
					<polyline points="21 15 16 10 5 21"></polyline>
				</svg>
				<h3>Aucun média</h3>
				<p>Uploadez votre première image pour commencer</p>
			</div>
		{% endif %}
	</div>

	<script nonce="{{ csp_nonce() }}">
		document.addEventListener('DOMContentLoaded', function () {
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
const selectFileBtn = document.getElementById('selectFileBtn');
const uploadProgress = document.getElementById('uploadProgress');
const progressFill = document.getElementById('progressFill');
const uploadStatus = document.getElementById('uploadStatus');
const mediaGrid = document.getElementById('mediaGrid');
const uploadHint = document.getElementById('uploadHint');
const uploadTypeBtns = document.querySelectorAll('.upload-type-btn');

let currentUploadType = 'image';

// Gérer le changement de type d'upload
uploadTypeBtns.forEach(btn => {
btn.addEventListener('click', function () {
uploadTypeBtns.forEach(b => b.classList.remove('active'));
this.classList.add('active');
currentUploadType = this.dataset.type;

if (currentUploadType === 'image') {
fileInput.accept = 'image/jpeg,image/png,image/gif,image/webp,image/svg+xml';
uploadHint.textContent = 'JPG, PNG, GIF, WebP ou SVG (Max 5MB)';
} else {
fileInput.accept = '.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip,.rar,.7z,.tar,.gz';
uploadHint.textContent = 'PDF, Word, Excel, ZIP, etc. (Max 20MB)';
}
});
});

// Ouvrir le sélecteur de fichier
selectFileBtn.addEventListener('click', () => fileInput.click());

// Drag & Drop
['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
dropZone.addEventListener(eventName, preventDefaults, false);
});

function preventDefaults(e) {
e.preventDefault();
e.stopPropagation();
}['dragenter', 'dragover'].forEach(eventName => {
dropZone.addEventListener(eventName, () => dropZone.classList.add('drag-over'), false);
});

['dragleave', 'drop'].forEach(eventName => {
dropZone.addEventListener(eventName, () => dropZone.classList.remove('drag-over'), false);
});

dropZone.addEventListener('drop', function (e) {
const files = e.dataTransfer.files;
if (files.length > 0) {
uploadFile(files[0]);
}
});

fileInput.addEventListener('change', function () {
if (this.files.length > 0) {
uploadFile(this.files[0]);
}
});

// Upload de fichier
async function uploadFile(file) {
const formData = new FormData();
formData.append('file', file);
formData.append('fileType', currentUploadType);

dropZone.style.display = 'none';
uploadProgress.style.display = 'block';
progressFill.style.width = '0%';
uploadStatus.textContent = 'Upload en cours...';

try {
await fetch('{{ path('admin_media_upload') }}', {
method: 'POST',
body: formData
});

// Si on arrive ici, l'upload est fait (réussi ou non)
progressFill.style.width = '100%';
uploadStatus.textContent = 'Upload réussi !';

// Recharger la page après un court délai
setTimeout(() => {
window.location.reload();
}, 600);

} catch (error) { // Erreur réseau uniquement
console.error('Upload error:', error);
uploadStatus.textContent = 'Erreur réseau';
uploadStatus.style.color = '#ef4444';

setTimeout(() => {
dropZone.style.display = 'flex';
uploadProgress.style.display = 'none';
uploadStatus.style.color = '';
}, 3000);
}
}

// Supprimer un média
document.querySelectorAll('.delete-media-btn').forEach(btn => {
btn.addEventListener('click', async function () {
if (!confirm('Êtes-vous sûr de vouloir supprimer ce fichier ?')) {
return;
}

const filename = this.dataset.filename;
const mediaItem = this.closest('.media-item');

try {
const response = await fetch(`{{ path('admin_media_delete', {'filename': '__FILENAME__'}) }}`.replace('__FILENAME__', filename), {method: 'POST'});

if (! response.ok) {
throw new Error('Erreur lors de la suppression');
}

mediaItem.style.opacity = '0';
setTimeout(() => mediaItem.remove(), 300);
showToast('Fichier supprimé');

} catch (error) {
showToast('Erreur: ' + error.message, 'error');
}
});
});

// Toast notification
function showToast(message, type = 'success') {
const toast = document.createElement('div');
toast.className = `toast toast-${type}`;
toast.textContent = message;
toast.style.cssText = `
            position: fixed;
            top: 2rem;
            right: 2rem;
            background: ${
type === 'success' ? '#10b981' : '#ef4444'
};
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 0.5rem;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            z-index: 10000;
            animation: slideIn 0.3s ease;
        `;
document.body.appendChild(toast);

setTimeout(() => {
toast.style.animation = 'slideOut 0.3s ease';
setTimeout(() => toast.remove(), 300);
}, 3000);
}
});
	</script>

	<style>
		@keyframes slideIn {
			from {
				transform: translateX(100%);
				opacity: 0;
			}
			to {
				transform: translateX(0);
				opacity: 1;
			}
		}

		@keyframes slideOut {
			from {
				transform: translateX(0);
				opacity: 1;
			}
			to {
				transform: translateX(100%);
				opacity: 0;
			}
		}
	</style>
{% endblock %}
