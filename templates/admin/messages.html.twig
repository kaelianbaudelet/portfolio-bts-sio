{% extends 'admin/base.html.twig' %}

{% block title %}Messages{% endblock %}

{% block body %}
    <div class="admin-header">
        <div>
            <h1 class="admin-page-title">Messages</h1>
            <p class="admin-page-subtitle">Gérez les messages reçus depuis le formulaire de contact</p>
        </div>
    </div>
    <div class="admin-section">
        {% if messages|length == 0 %}
            <div class="admin-empty-state">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                <h3>Aucun message</h3>
                <p>Vous n’avez pas encore reçu de message via le formulaire de contact.</p>
            </div>
        {% else %}
            <div class="admin-table-container">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th style="width: 90px;">Statut</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Sujet</th>
                            <th style="width: 170px;">Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for message in messages %}
                            <tr id="message-{{ message.id }}" class="{% if not message.isRead %}admin-table-row-unread{% endif %}">
                                <td>
                                    {% if message.isRead %}
                                        <span class="badge badge-secondary">Lu</span>
                                    {% else %}
                                        <span class="badge badge-success">Nouveau</span>
                                    {% endif %}
                                </td>
                                <td><strong>{{ message.name }}</strong></td>
                                <td>
                                    <a href="mailto:{{ message.email }}" class="admin-link">{{ message.email }}</a>
                                </td>
                                <td>
                                    <details>
                                        <summary><strong>{{ message.subject }}</strong></summary>
                                        <div class="admin-message-preview" style="margin-top: 0.5em;">
                                            {{ message.message|raw }}
                                        </div>
                                    </details>
                                </td>
                                <td>{{ message.createdAt|date('d/m/Y H:i') }}</td>
                                <td>
                                    <div class="admin-table-actions">
                                        <button onclick="viewMessage({{ message.id }}, {{ message.name|json_encode }}, {{ message.email|json_encode }}, {{ message.subject|json_encode }}, {{ message.message|json_encode }}, '{{ message.createdAt|date('d/m/Y H:i') }}', {{ message.isRead ? 'true' : 'false' }})" class="admin-table-action" title="Voir">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                <circle cx="12" cy="12" r="3"></circle>
                                            </svg>
                                        </button>
                                        {% if not message.isRead %}
                                            <button onclick="markAsRead({{ message.id }})" class="admin-table-action admin-table-action-success" title="Marquer comme lu">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                            </button>
                                        {% endif %}
                                        <button onclick="deleteMessage({{ message.id }})" class="admin-table-action admin-table-action-danger" title="Supprimer">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
    <!-- Modal pour l'affichage des détails du message -->
    <div id="messageModal" class="admin-modal">
        <div class="admin-modal-overlay" onclick="closeMessageModal()"></div>
        <div class="admin-modal-content">
            <div class="admin-modal-header">
                <h3 class="admin-modal-title">Détails du message</h3>
                <button onclick="closeMessageModal()" class="admin-modal-close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <div class="admin-modal-body">
                <dl class="admin-modal-fields">
                    <dt>De&nbsp;:</dt>
                    <dd id="modalName"></dd>
                    <dt>Email&nbsp;:</dt>
                    <dd><a id="modalEmail" href="" class="admin-link"></a></dd>
                    <dt>Sujet&nbsp;:</dt>
                    <dd id="modalSubject"></dd>
                    <dt>Date&nbsp;:</dt>
                    <dd id="modalDate"></dd>
                </dl>
                <div class="admin-modal-message-content">
                    <strong>Message&nbsp;:</strong>
                    <div id="modalMessage" style="white-space: pre-line; margin-top:0.5em;"></div>
                </div>
            </div>
            <div class="admin-modal-footer">
                <button id="modalReplyBtn" class="btn btn-primary">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 17 4 12 9 7"></polyline>
                        <path d="M20 18v-2a4 4 0 0 0-4-4H4"></path>
                    </svg>
                    Répondre
                </button>
                <button onclick="closeMessageModal()" class="btn btn-secondary">Fermer</button>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
	<script nonce="{{ csp_nonce() }}">
	let currentMessageId = null;

	function viewMessage(id, name, email, subject, message, date, isRead) {
	    currentMessageId = id;
	    document.getElementById('modalName').textContent = name;
	    document.getElementById('modalEmail').textContent = email;
	    document.getElementById('modalEmail').href = 'mailto:' + email;
	    document.getElementById('modalSubject').textContent = subject;
	    document.getElementById('modalMessage').textContent = message;
	    document.getElementById('modalDate').textContent = date;
	    document.getElementById('modalReplyBtn').onclick = () => window.location.href = 'mailto:' + email + '?subject=Re: ' + subject;
	    document.getElementById('messageModal').classList.add('active');
	    if (!isRead) {
	        markAsRead(id);
	    }
	}

	function closeMessageModal() {
	    document.getElementById('messageModal').classList.remove('active');
	}

	async function markAsRead(id) {
	    try {
	        const response = await fetch(`/admin/messages/${id}/read`, {
	            method: 'POST',
	            headers: {
	                'Content-Type': 'application/json',
	            }
	        });

	        if (response.ok) {
	            const row = document.getElementById(`message-${id}`);
	            if (row) {
	                row.classList.remove('admin-table-row-unread');
	                const badge = row.querySelector('.badge-success, .admin-badge-success, .badge-secondary, .admin-badge-secondary');
	                if (badge) {
	                    badge.className = 'badge badge-secondary';
	                    badge.textContent = 'Lu';
	                }
	                const actionsCell = row.querySelector('.admin-table-actions');
	                const readBtn = actionsCell.querySelector('.admin-table-action-success');
	                if (readBtn) {
	                    readBtn.remove();
	                }
	            }
	        }
	    } catch (error) {
	        console.error('Error marking message as read:', error);
	    }
	}

	async function deleteMessage(id) {
	    if (!confirm('Êtes-vous sûr de vouloir supprimer ce message ?')) {
	        return;
	    }

	    try {
	        const response = await fetch(`/admin/messages/${id}/delete`, {
	            method: 'POST',
	            headers: {
	                'Content-Type': 'application/json',
	            }
	        });

	        if (response.ok) {
	            const row = document.getElementById(`message-${id}`);
	            if (row) {
	                row.style.opacity = '0';
	                setTimeout(() => row.remove(), 300);
	            }
	        }
	    } catch (error) {
	        console.error('Error deleting message:', error);
	        alert('Une erreur est survenue lors de la suppression du message.');
	    }
	}
	</script>
{% endblock %}
