		<!-- Preloader CSS - Chargé en premier -->
		<style>:root
		{
			--bg-primary: #ffffff;
			--bg-secondary: #f8f9fa;
			--text-secondary: #6c757d;
			--accent-color: #0ea5e9;
			--border-color: #dee2e6;
		}

		[data-theme="dark"] {
			--bg-primary: #1a1a1a;
			--bg-secondary: #2d2d2d;
			--text-secondary: #adb5bd;
			--accent-color: #0ea5e9;
			--border-color: #495057;
		}

		.page-preloader {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background-color: var(--bg-primary);
			display: flex;
			align-items: center;
			justify-content: center;
			z-index: 9999;
			opacity: 0;
			visibility: hidden;
			transition: opacity 0.5s ease, visibility 0.5s ease;
		}

		.page-preloader.hidden {
			opacity: 0;
			visibility: hidden;
		}

		.page-preloader-content {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 1.5rem;
		}

		.page-preloader .spinner {
			width: 48px;
			height: 48px;
			border: 4px solid var(--border-color);
			border-top-color: var(--accent-color);
			border-radius: 50%;
			animation: spin 0.8s linear infinite;
		}

		.page-preloader p {
			color: var(--text-secondary);
			font-size: 1rem;
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		}

		@keyframes spin {
			to {
				transform: rotate(360deg);
			}
		}
	</style>

	<!-- Preloader JS - Exécuté immédiatement -->
	<script nonce="{{ csp_nonce() }}">
		// Appliquer le thème immédiatement
const savedTheme = localStorage.getItem("theme") || "light";
document.documentElement.setAttribute("data-theme", savedTheme);

// Gestion du preloader
const preloaderState = {
visible: false,
loaded: false
};

// Montrer le preloader seulement si le chargement prend plus de 200ms
const showTimer = setTimeout(() => {
if (! preloaderState.loaded) {
const preloader = document.getElementById("pagePreloader");
if (preloader) {
preloader.style.opacity = "1";
preloader.style.visibility = "visible";
preloaderState.visible = true;
}
}
}, 300);

// Cacher le preloader quand la page est chargée
window.addEventListener("load", () => {
preloaderState.loaded = true;
clearTimeout(showTimer);

const preloader = document.getElementById("pagePreloader");
if (preloader) {
if (preloaderState.visible) {
const minDisplayTime = 500;
const elapsedTime = performance.now();
const remainingTime = Math.max(0, minDisplayTime - elapsedTime);

setTimeout(() => {
preloader.classList.add("hidden");
setTimeout(() => {
preloader.remove();
}, 500);
}, remainingTime);
} else { // Sinon, supprimer immédiatement
preloader.remove();
}
}
});
	</script>

	<link rel="icon" href="{{ asset('assets/favicons/favicon.ico') }}">
	<link rel="stylesheet" href="{{ asset('assets/styles/app.css') }}"> {% block stylesheets %}{% endblock %}
	</head>
