{% extends 'base.html.twig' %}

{% block title %}Plan du site
{% endblock %}

{% block body %}
	<main class="main">
		{# Page Hero #}
		<section class="page-hero">
			<div class="container">
				<h1 class="page-title fade-up">Plan du site</h1>
				<p class="page-subtitle fade-up delay-200">Retrouvez l'ensemble des pages de ce portfolio organisées par catégorie.</p>
			</div>
		</section>

		{# Sitemap Section #}
		<section class="sitemap-section">
			<div class="container">
				<div class="sitemap-grid">
					{# Pages principales #}
					<div class="sitemap-category fade-up delay-300">
						<div class="sitemap-category-card">
							<div class="sitemap-category-icon">
								<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
									<polyline points="9 22 9 12 15 12 15 22"></polyline>
								</svg>
							</div>
							<h2 class="sitemap-category-title">Pages principales</h2>
							<ul class="sitemap-links">
								<li>
									<a href="{{ path('app_home') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Accueil
									</a>
								</li>
								<li>
									<a href="{{ path('app_about') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										À propos
									</a>
								</li>
								<li>
									<a href="{{ path('app_contact') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Contact
									</a>
								</li>
							</ul>
						</div>
					</div>

					{# Compétences & Certifications #}
					<div class="sitemap-category fade-up delay-400">
						<div class="sitemap-category-card">
							<div class="sitemap-category-icon">
								<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
									<path d="M6 12v5c3 3 9 3 12 0v-5"></path>
								</svg>
							</div>
							<h2 class="sitemap-category-title">Compétences & Formations</h2>
							<ul class="sitemap-links">
								<li>
									<a href="{{ path('app_skills') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Compétences
									</a>
								</li>
								<li>
									<a href="{{ path('app_certifications') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Certifications
									</a>
								</li>
							</ul>
						</div>
					</div>

					{# Projets & Veille #}
					<div class="sitemap-category fade-up delay-500">
						<div class="sitemap-category-card">
							<div class="sitemap-category-icon">
								<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
									<line x1="8" y1="21" x2="16" y2="21"></line>
									<line x1="12" y1="17" x2="12" y2="21"></line>
								</svg>
							</div>
							<h2 class="sitemap-category-title">Réalisations</h2>
							<ul class="sitemap-links">
								<li>
									<a href="{{ path('app_projects') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Projets
									</a>
								</li>
								<li>
									<a href="{{ path('app_tech_watch') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Veille technologique
									</a>
								</li>
							</ul>
						</div>
					</div>

					{# Informations légales #}
					<div class="sitemap-category fade-up delay-600">
						<div class="sitemap-category-card">
							<div class="sitemap-category-icon">
								<svg width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
									<polyline points="14 2 14 8 20 8"></polyline>
									<line x1="16" y1="13" x2="8" y2="13"></line>
									<line x1="16" y1="17" x2="8" y2="17"></line>
									<polyline points="10 9 9 9 8 9"></polyline>
								</svg>
							</div>
							<h2 class="sitemap-category-title">Informations légales</h2>
							<ul class="sitemap-links">
								<li>
									<a href="{{ path('app_legals') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Mentions légales
									</a>
								</li>
								<li>
									<a href="{{ path('app_privacy') }}" class="sitemap-link">
										<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="9 18 15 12 9 6"></polyline>
										</svg>
										Politique de confidentialité
									</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
{% endblock %}
